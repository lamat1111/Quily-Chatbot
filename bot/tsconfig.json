{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "..",
    "baseUrl": ".",
    "paths": {
      "@/lib/*": ["../src/lib/*"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "../src/lib/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
