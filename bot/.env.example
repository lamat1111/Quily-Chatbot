# Discord
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

# LLM Provider — "openrouter" or "chutes" (default: openrouter)
BOT_LLM_PROVIDER=openrouter

# OpenRouter (required if BOT_LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=your_openrouter_key_here

# Chutes (required if BOT_LLM_PROVIDER=chutes)
CHUTES_API_KEY=your_chutes_api_key_here

# Supabase (same credentials as web app — must use these exact var names)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_key

# RAG reranking
COHERE_API_KEY=your_cohere_key

# Cloudflare Workers AI (fallback reranker when Cohere is unavailable)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Channel restriction — bot only replies here for regular users
DISCORD_QUILY_CHANNEL_ID=1484286515944226876
# Comma-separated role IDs that can use the bot in any channel
# Overseer, Community Mod, Announcers, Chief Insomniac, Q Employee
DISCORD_PRIVILEGED_ROLE_IDS=1213165531805524110,1228410961891950662,1260031057890246658,1331054709234073640,1432763195243761874

# Bot config
DISCORD_DAILY_LIMIT=200
BOT_MODEL=
BOT_FALLBACK_MODELS=
MAX_MESSAGE_LENGTH=2000
